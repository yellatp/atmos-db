name = "atmos-sdk"
main = "examples/basic-crud/worker.ts"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

# Configure your D1 database
# Create one at: https://dash.cloudflare.com/ -> D1
[[d1_databases]]
binding = "DB"
database_name = "your-database-name"
database_id = "your-database-id"

# Configure your Vectorize index
# Create one at: https://dash.cloudflare.com/ -> Vectorize
[[vectorize]]
binding = "VECTORIZE"
index_name = "your-vector-index"

# Configure your R2 bucket
# Create one at: https://dash.cloudflare.com/ -> R2
[[r2_buckets]]
binding = "BUCKET"
bucket_name = "your-bucket-name"

# Configure Workers AI (optional)
# Enable at: https://dash.cloudflare.com/ -> Workers AI
[ai]
binding = "AI"
